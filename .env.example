# code-for-humans — variables de entorno
# Copia este archivo a .env.local y rellena tus valores

# Requerido — consigue tu clave en https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-tu-clave-aqui

# Opcional — personaliza el modelo de Claude usado
# Por defecto: claude-sonnet-4-20250514
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Opcional — máximo de tokens para las respuestas (por defecto: 1024)
# ANTHROPIC_MAX_TOKENS=1024
